{
  "name": "thezonepos",
  "version": "1.0.0",
  "description": "TheZonePOS - Restaurant POS System",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "build:win": "electron-builder --win",
    "build:portable": "electron-builder --win portable",
    "build:installer": "electron-builder --win nsis"
  },
  "author": "WEB2POS",
  "license": "MIT",
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  },
  "dependencies": {
    "electron-store": "^8.1.0"
  },
  "build": {
    "appId": "com.thezone.pos",
    "productName": "TheZonePOS",
    "directories": {
      "output": "dist"
    },
    "icon": "icon.png",
    "files": [
      "main.js",
      "preload.js",
      "frontend-build/**/*"
    ],
    "extraResources": [
      {
        "from": "db",
        "to": "db",
        "filter": ["**/*"]
      },
      {
        "from": "node.exe",
        "to": "node.exe"
      },
      {
        "from": "backend",
        "to": "backend",
        "filter": [
          "**/*",
          "!node_modules/.cache/**",
          "!uploads/**",
          "!**/test/**",
          "!**/*.map"
        ]
      },
      {
        "from": "frontend-build",
        "to": "frontend-build",
        "filter": ["**/*"]
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        },
        {
          "target": "portable",
          "arch": ["x64"]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "TheZonePOS"
    },
    "portable": {
      "artifactName": "${productName}-Portable-${version}.${ext}"
    }
  }
}
