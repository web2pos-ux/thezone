## Example: Android release signing for sideload (NOT Play Store)
#
# Copy this file to: android/keystore.properties   (do NOT commit)
# Then fill in the values below.
#
# MYAPP_RELEASE_STORE_FILE=keystore/table-order-release.keystore
# MYAPP_RELEASE_STORE_PASSWORD=YOUR_STORE_PASSWORD
# MYAPP_RELEASE_KEY_ALIAS=table-order
# MYAPP_RELEASE_KEY_PASSWORD=YOUR_KEY_PASSWORD

